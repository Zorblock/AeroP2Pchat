{
  "name": "aerop2p",
  "private": true,
  "version": "26.19.0",
  "type": "module",
  "scripts": {
    "start": "tauri dev",
    "start:2": "set AEROP2P_PROFILE=2&& set WEBVIEW2_USER_DATA_FOLDER=%LOCALAPPDATA%\\AeroP2P\\Profile2&& start src-tauri/target/debug/aerop2p.exe",
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "npm run build && node --check scripts/ci-build-release.cjs && node --check scripts/ci-create-latest.cjs && node --check scripts/deploy-pages.cjs && node --check scripts/release-help.cjs && node --check scripts/release.cjs && cargo check --manifest-path src-tauri/Cargo.toml",
    "release": "node scripts/release-help.cjs",
    "release:dry": "node scripts/release-help.cjs --dry-run",
    "patch": "node scripts/release-help.cjs --patch",
    "pages": "node scripts/deploy-pages.cjs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "peerjs": "^1.5.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "vite": "^7.3.5"
  }
}
